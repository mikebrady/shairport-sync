--- a/configure.ac	2026-03-25 14:58:41
+++ b/configure.ac	2026-03-25 14:58:14
@@ -11,6 +11,7 @@
 build_linux=no
 build_freebsd=no
 build_openbsd=no
+build_darwin=no
 
 # Detect the target system
 case "${host_os}" in
@@ -23,6 +24,9 @@
     openbsd*)
         build_openbsd=yes
         ;;
+    darwin*)
+        build_darwin=yes
+        ;;
     *)
         AC_MSG_ERROR(["OS $host_os is not supported"])
         ;;
@@ -32,6 +36,7 @@
 AM_CONDITIONAL([BUILD_FOR_LINUX], [test "$build_linux" = "yes"])
 AM_CONDITIONAL([BUILD_FOR_FREEBSD], [test "$build_freebsd" = "yes"])
 AM_CONDITIONAL([BUILD_FOR_OPENBSD], [test "$build_openbsd" = "yes"])
+AM_CONDITIONAL([BUILD_FOR_DARWIN], [test "$build_darwin" = "yes"])
 
 if test "x$build_linux" = "xyes" ; then
   AC_DEFINE([CONFIG_FOR_LINUX], 1, [Build for Linux.])
@@ -42,6 +47,9 @@
 if test "x$build_openbsd" = "xyes" ; then
   AC_DEFINE([CONFIG_FOR_OPENBSD], 1, [Build for OpenBSD.])
 fi
+if test "x$build_darwin" = "xyes" ; then
+  AC_DEFINE([CONFIG_FOR_DARWIN], 1, [Build for Darwin/macOS.])
+fi
 
 AC_CHECK_PROGS([GIT], [git])
 if test -n "$GIT" && test -e ".git/index" ; then
@@ -68,8 +76,8 @@
 
 # Checks for libraries.
 AC_CHECK_LIB([pthread],[pthread_create], , AC_MSG_ERROR(pthread library needed))
-if test "x$build_openbsd" = "xno" ; then
-  # part of libc
+if test "x$build_openbsd" = "xno" -a "x$build_darwin" = "xno" ; then
+  # part of libc on OpenBSD and macOS
   AC_CHECK_LIB([rt],[clock_gettime], , AC_MSG_ERROR(librt needed for shared memory library))
 fi
 
--- a/check-gitversion	2026-03-25 14:58:41
+++ b/check-gitversion	2026-03-25 14:58:35
@@ -12,7 +12,7 @@
   echo $GD > gitversion-stamp
   echo "// Do not edit!" > gitversion.h
 	echo "// This file is automatically generated." >> gitversion.h
-	echo -n "  char git_version_string[] = \"" >> gitversion.h
+	printf '%s' '  char git_version_string[] = "' >> gitversion.h
 	## the tr is because we need to remove the trailing newline
 	cat gitversion-stamp | tr -d '[[:space:]]' >> gitversion.h
 	echo "\";" >> gitversion.h
